# Copy this file to .env and fill in your values.
# These power the daily reminder bot (bot/check-and-notify.js, server-side, keep secret):

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
TELEGRAM_TOKEN=123456:ABC-your-bot-token

# The Telegram webhook (web/api/handle-message.js, deployed on Vercel) needs these same
# three server-side secrets PLUS a Gemini key. Set them as Vercel Environment Variables:
# SUPABASE_URL, SUPABASE_KEY, TELEGRAM_TOKEN, and:
GEMINI_API_KEY=your-google-ai-studio-key

# For the web app front-end (web/.env), use the PUBLIC keys instead:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
